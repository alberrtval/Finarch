<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cl_principalSc"
    tools:context=".MainActivity">

    <ScrollView
        android:id="@+id/scrollDashboard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/dashboardContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="22dp"
            android:paddingBottom="22dp">

            <!-- Header con acceso a perfil -->
            <LinearLayout
                android:id="@+id/headerRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvAppTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Finarch"
                        android:fontFamily="@font/rock_regular"
                        android:textColor="@color/cl_divisor"
                        android:textSize="34sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvMonth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Resumen del mes"
                        android:textColor="@color/cl_text_ter"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_regular"
                        android:letterSpacing="0.04"/>
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnProfile"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="2dp"
                    app:cardUseCompatPadding="true"
                    app:cardBackgroundColor="@color/cl_texto_princ">

                    <ImageView
                        android:id="@+id/imgProfile"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="2dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_person_24"/>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Seción de ingresos y dinero disponible-->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_card_balance">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardBalance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardUseCompatPadding="true"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvBalanceLabel"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Saldo disponible"
                                android:textColor="@color/white"
                                android:textSize="14sp"
                                android:fontFamily="@font/inter_regular"
                                android:alpha="0.9"/>

                            <ImageView
                                android:id="@+id/ivToggleBalance"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_visibility"
                                android:alpha="0.8"
                                android:padding="2dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:tint="@color/white"/>

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvBalanceValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$ 1,250.00"
                            android:textColor="@color/white"
                            android:textSize="40sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_regular"
                            android:layout_marginTop="6dp"/>

                        <TextView
                            android:id="@+id/tvBalanceHint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Actualizado hoy"
                            android:textColor="@color/cl_texto_princ"
                            android:textSize="12sp"
                            android:fontFamily="@font/inter_regular"
                            android:alpha="0.8"
                            android:layout_marginTop="6dp"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <!-- Seccion de resumen-->
            <LinearLayout
                android:id="@+id/rowSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp"
                android:weightSum="2">

                <!-- Ingresos -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardIncome"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardUseCompatPadding="true"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/cl_secundarioSc">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvIncomeLabel"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Ingresos"
                                android:textColor="@color/white"
                                android:textSize="13sp"
                                android:fontFamily="@font/inter_regular"
                                android:alpha="0.9"/>

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_arrow_upward"
                                app:tint="#4CAF50"/>

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvIncomeValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:fontFamily="@font/inter_regular"
                            android:text="$ 2,000.00"
                            android:textColor="@color/white"
                            android:textSize="22sp"
                            android:textStyle="bold"/>

                        <!-- Barra de progreso ingresos -->
                        <ProgressBar
                            android:id="@+id/progressIncome"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="10dp"
                            android:progress="0"
                            android:max="100"
                            android:progressDrawable="@drawable/progress_income"/>

                        <TextView
                            android:id="@+id/tvIncomeHint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0% de meta"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:fontFamily="@font/inter_regular"
                            android:alpha="0.7"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Gastos -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardExpense"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardUseCompatPadding="true"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/cl_secundarioSc">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvExpenseLabel"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Gastos"
                                android:textColor="@color/white"
                                android:textSize="13sp"
                                android:fontFamily="@font/inter_regular"
                                android:alpha="0.9"/>

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_arrow_downward"
                                app:tint="#F44336"/>

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvExpenseValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:fontFamily="@font/inter_regular"
                            android:text="$ 750.00"
                            android:textColor="@color/white"
                            android:textSize="22sp"
                            android:textStyle="bold"/>

                        <!-- Barra de progreso gastos -->
                        <ProgressBar
                            android:id="@+id/progressExpense"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="10dp"
                            android:progress="0"
                            android:max="100"
                            android:progressDrawable="@drawable/progress_expense"/>

                        <TextView
                            android:id="@+id/tvExpenseHint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0% del presupuesto"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:fontFamily="@font/inter_regular"
                            android:alpha="0.7"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Sección de alertas -->
            <TextView
                android:id="@+id/tvAlertsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alertas"
                android:textColor="@color/cl_texto_princ"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/inter_regular"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAlerts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardUseCompatPadding="true"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/cl_tercero">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvAlerts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:nestedScrollingEnabled="false"/>

            </com.google.android.material.card.MaterialCardView>

            <!-- Accesos directos -->
            <TextView
                android:id="@+id/tvActionsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accesos rápidos"
                android:textColor="@color/cl_texto_princ"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/inter_regular"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:weightSum="2">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnIngresoMovimiento"
                    style="@style/FinarchButton3D"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Agregar"
                    android:textColor="@color/cl_texto_princ"
                    android:layout_marginEnd="8dp"
                    app:icon="@drawable/ic_add_24"
                    app:iconGravity="textStart"
                    app:iconTint="@color/cl_texto_princ"
                    app:iconSize="18dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReportsMain"
                    style="@style/FinarchButton3D"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Reportes"
                    android:textColor="@color/cl_texto_princ"
                    android:layout_marginStart="8dp"
                    app:icon="@drawable/ic_calendar_24"
                    app:iconGravity="textStart"
                    app:iconTint="@color/cl_texto_princ"
                    app:iconSize="18dp"/>

            </LinearLayout>

            <!-- Apartado donde iran las noticias -->
            <TextView
                android:id="@+id/tvNewsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Noticias"
                android:textColor="@color/cl_texto_princ"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/inter_regular"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="10dp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="180dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_newspaper"
                        android:alpha="0.3"
                        app:tint="@color/cl_texto_princ"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="Noticias próximamente"
                        android:textColor="@color/cl_texto_princ"
                        android:alpha="0.4"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_regular"/>
                </LinearLayout>
            </FrameLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
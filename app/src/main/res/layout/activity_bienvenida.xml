<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".bienvenida"
    android:background="@color/cl_principalSc">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_margin="16dp"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Finarch"
            android:fontFamily="@font/rock_regular"
            android:textColor="@color/cl_divisor"
            android:textSize="64sp"
            android:textStyle="bold"
            android:layout_marginBottom="-10dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="!Tu amigo financiero¡"
            android:textSize="18sp"
            android:layout_marginBottom="24dp"
            android:textColor="@color/cl_text_ter"
            android:gravity="center"
            android:letterSpacing="0.1"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnInicioSesion"
            style="@style/FinarchButton3D"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Iniciar sesión"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:textColor="@color/cl_texto_princ"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvRegistrar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="¿No tienes cuenta? Regístrate"
            android:textSize="14sp"
            android:layout_marginBottom="16dp"
            android:textColor="@color/cl_texto_sec"
            android:gravity="center" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
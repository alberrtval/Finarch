<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cl_secundarioSc"
    tools:context=".ui.auth.RegistrarUsuario">


    <LinearLayout
        android:id="@+id/loginContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Finarch"
        android:fontFamily="@font/rock_regular"
        android:textColor="@color/cl_divisor"
        android:textSize="56sp"
        android:textStyle="bold"
        android:layout_marginBottom="-10dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="El primer paso a tus finanzas"
        android:textColor="@color/cl_principalSc"
        android:textSize="16sp"
        android:letterSpacing="0.04"
        android:layout_marginBottom="20dp"
        android:gravity="center" />

    <!--Input del nombre completo-->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilNombre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColorHint="@color/cl_texto_princ"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:hintTextColor="@color/cl_texto_princ"
        app:boxStrokeColor="@color/cl_divisor"
        android:layout_marginBottom="2dp"
        app:boxBackgroundMode="outline"
        app:boxBackgroundColor="@color/cl_secundario">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etNombre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nombre completo"
            android:inputType="textEmailAddress"
            android:textColor="@color/cl_texto_princ"
            android:textSize="16sp"
            android:fontFamily="@font/inter_regular"
            android:padding="12dp"/>
    </com.google.android.material.textfield.TextInputLayout>

        <!--Input del correo-->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColorHint="@color/cl_texto_princ"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:hintTextColor="@color/cl_texto_princ"
        app:boxStrokeColor="@color/cl_divisor"
        android:layout_marginBottom="2dp"
        app:boxBackgroundMode="outline"
        app:boxBackgroundColor="@color/cl_secundario">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Correo"
            android:inputType="textEmailAddress"
            android:textColor="@color/cl_texto_princ"
            android:textSize="16sp"
            android:fontFamily="@font/inter_regular"
            android:padding="12dp"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!--Input de la contraseña-->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColorHint="@color/cl_texto_princ"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:endIconMode="password_toggle"
        app:hintTextColor="@color/cl_texto_princ"
        app:boxStrokeColor="@color/cl_divisor"
        android:layout_marginBottom="2dp"
        app:boxBackgroundColor="@color/cl_secundario">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Contraseña"
            android:inputType="textPassword"
            android:textColor="@color/cl_texto_princ"
            android:textSize="16sp"
            android:fontFamily="@font/inter_regular"
            android:padding="12dp"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!--Input de la contraseña-->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilConPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColorHint="@color/cl_texto_princ"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:endIconMode="password_toggle"
        app:hintTextColor="@color/cl_texto_princ"
        app:boxStrokeColor="@color/cl_divisor"
        android:layout_marginBottom="16dp"
        app:boxBackgroundColor="@color/cl_secundario">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etconPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Confirma la contraseña"
            android:inputType="textPassword"
            android:textColor="@color/cl_texto_princ"
            android:textSize="16sp"
            android:fontFamily="@font/inter_regular"
            android:padding="12dp"/>
    </com.google.android.material.textfield.TextInputLayout>


    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRegistrarse"
        style="@style/FinarchButton3D.Secundario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Registrarse"
        android:textColor="@color/cl_texto_princ"
        android:paddingStart="34dp"
        android:paddingEnd="34dp"
        android:layout_marginBottom="14dp"/>

    <TextView
        android:id="@+id/tvRegistrar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿Ya tienes cuenta? Inicia Sesión"
        android:textColor="@color/cl_texto_princ"
        android:textSize="14sp"
        android:fontFamily="@font/inter_regular"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
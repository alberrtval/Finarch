<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cl_principalSc"
    tools:context=".login">

    <LinearLayout
        android:id="@+id/loginContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Finarch"
            android:fontFamily="@font/rock_regular"
            android:textColor="@color/cl_divisor"
            android:textSize="56sp"
            android:textStyle="bold"
            android:layout_marginBottom="-10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Inicia sesión para continuar"
            android:textColor="@color/cl_text_ter"
            android:textSize="16sp"
            android:letterSpacing="0.06"
            android:layout_marginBottom="20dp"
            android:gravity="center" />

        <!--Input del correo-->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColorHint="@color/cl_texto_princ"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:hintTextColor="@color/cl_texto_princ"
            app:boxStrokeColor="@color/cl_divisor"
            android:layout_marginBottom="12dp"
            app:boxBackgroundMode="outline"
            app:boxBackgroundColor="@color/cl_principal">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Correo"
                android:inputType="textEmailAddress"
                android:textColor="@color/cl_texto_princ"
                android:textSize="16sp"
                android:fontFamily="@font/inter_regular"
                android:padding="12dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!--Input de la contraseña-->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColorHint="@color/cl_texto_princ"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:endIconMode="password_toggle"
            app:hintTextColor="@color/cl_texto_princ"
            app:boxStrokeColor="@color/cl_divisor"
            android:layout_marginBottom="8dp"
            app:boxBackgroundColor="@color/cl_principal">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contraseña"
                android:inputType="textPassword"
                android:textColor="@color/cl_texto_princ"
                android:textSize="16sp"
                android:fontFamily="@font/inter_regular"
                android:padding="12dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/tvOlvidar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿Olvidaste tu contraseña?"
            android:textColor="@color/cl_texto_sec"
            android:textSize="14sp"
            android:layout_marginBottom="16dp"
            android:fontFamily="@font/inter_regular"
            android:clickable="true"
            android:focusable="true"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            style="@style/FinarchButton3D"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Entrar"
            android:textColor="@color/cl_texto_princ"
            android:paddingStart="34dp"
            android:paddingEnd="34dp"
            android:layout_marginBottom="14dp"/>

        <TextView
            android:id="@+id/tvRegistrar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿No tienes cuenta? Regístrate"
            android:textColor="@color/cl_texto_sec"
            android:textSize="14sp"
            android:fontFamily="@font/inter_regular"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"/>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
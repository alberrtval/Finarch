<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cl_principalSc"
    tools:context=".ReportesResumen">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnBackreport"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Volver"
            android:scaleType="center"
            app:srcCompat="@drawable/ic_arrow_back_24"
            app:tint="@color/cl_text_ter"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Movimientos"
                android:textColor="@color/cl_divisor"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/inter_regular" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Historial completo"
                android:textColor="@color/cl_text_ter"
                android:textSize="13sp"
                android:fontFamily="@font/inter_regular"
                android:letterSpacing="0.03" />
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnExport"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Exportar"
            android:padding="8dp"
            android:scaleType="fitCenter"
            app:srcCompat="@drawable/ic_download_24"
            app:tint="@color/cl_text_ter"
            app:tintMode="src_in" />
    </LinearLayout>

    <!-- Barra de busqueda -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilSearch"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        android:hint="Buscar (ej. súper, salario, renta...)"
        android:textColorHint="@color/cl_text_ter"
        app:startIconDrawable="@drawable/ic_search_24"
        app:startIconTint="@color/cl_text_ter"
        app:endIconMode="clear_text"
        app:boxBackgroundMode="outline"
        app:boxBackgroundColor="@color/cl_secundario"
        app:boxCornerRadiusTopStart="14dp"
        app:boxCornerRadiusTopEnd="14dp"
        app:boxCornerRadiusBottomStart="14dp"
        app:boxCornerRadiusBottomEnd="14dp"
        app:boxStrokeWidth="0dp"
        app:boxStrokeWidthFocused="0dp"
        app:hintTextColor="@color/cl_text_ter"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/cl_texto_princ"
            android:textColorHint="@color/cl_text_ter"
            android:textSize="15sp"
            android:fontFamily="@font/inter_regular"
            android:padding="12dp"
            android:paddingStart="44dp"
            android:inputType="text" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Seccion de filtro de busquedas -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardFilters"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="18dp"
        app:cardUseCompatPadding="true"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/cl_secundario"
        app:layout_constraintTop_toBottomOf="@id/tilSearch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/filtersContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/tvFiltersTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Filtros"
                    android:textColor="@color/cl_texto_princ"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter_regular" />

                <TextView
                    android:id="@+id/tvClearFilters"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Limpiar"
                    android:textColor="@color/cl_text_ter"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter_regular"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="10dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilDateFrom"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:hint="Desde"
                    android:textColorHint="@color/cl_text_ter"
                    app:endIconMode="custom"
                    app:endIconDrawable="@drawable/ic_calendar_24"
                    app:endIconTint="@color/cl_text_ter"
                    app:boxBackgroundMode="outline"
                    app:boxBackgroundColor="@color/cl_secundarioSc"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:hintTextColor="@color/cl_text_ter">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDateFrom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:focusable="false"
                        android:clickable="true"
                        android:textColor="@color/cl_texto_princ"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_regular"
                        android:padding="12dp"
                        android:text=""/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilDateTo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:hint="Hasta"
                    android:textColorHint="@color/cl_text_ter"
                    app:endIconMode="custom"
                    app:endIconDrawable="@drawable/ic_calendar_24"
                    app:endIconTint="@color/cl_text_ter"
                    app:boxBackgroundMode="outline"
                    app:boxBackgroundColor="@color/cl_secundarioSc"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:hintTextColor="@color/cl_text_ter">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDateTo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:focusable="false"
                        android:clickable="true"
                        android:textColor="@color/cl_texto_princ"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_regular"
                        android:padding="12dp"
                        android:text=""/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="10dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilCategory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:hint="Categoría"
                    android:textColorHint="@color/cl_text_ter"
                    app:endIconMode="dropdown_menu"
                    app:boxBackgroundMode="outline"
                    app:boxBackgroundColor="@color/cl_secundarioSc"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:hintTextColor="@color/cl_text_ter">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/acCategory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textColor="@color/cl_texto_princ"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_regular"
                        android:padding="12dp"
                        android:entries="@array/categories_list" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilSort"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:hint="Orden"
                    android:textColorHint="@color/cl_text_ter"
                    app:endIconMode="dropdown_menu"
                    app:boxBackgroundMode="outline"
                    app:boxBackgroundColor="@color/cl_secundarioSc"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:hintTextColor="@color/cl_text_ter">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/acSort"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textColor="@color/cl_texto_princ"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_regular"
                        android:padding="12dp"
                        android:entries="@array/sort_list" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="10dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilMinAmount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:hint="Monto mín."
                    android:textColorHint="@color/cl_text_ter"
                    app:boxBackgroundMode="outline"
                    app:boxBackgroundColor="@color/cl_secundarioSc"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:hintTextColor="@color/cl_text_ter">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMinAmount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="@color/cl_texto_princ"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_regular"
                        android:padding="12dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilMaxAmount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:hint="Monto máx."
                    android:textColorHint="@color/cl_text_ter"
                    app:boxBackgroundMode="outline"
                    app:boxBackgroundColor="@color/cl_secundarioSc"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:hintTextColor="@color/cl_text_ter">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMaxAmount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="@color/cl_texto_princ"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_regular"
                        android:padding="12dp" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tipo"
                android:textColor="@color/cl_text_ter"
                android:textSize="13sp"
                android:fontFamily="@font/inter_regular"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="false"
                android:layout_marginBottom="12dp">

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/chipAll"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:text="Todos"
                    android:checked="true" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/chipIncome"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:text="Ingreso" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/chipExpense"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:text="Gasto" />
            </com.google.android.material.chip.ChipGroup>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:weightSum="2">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnApplyFilters"
                    style="@style/FinarchButton3D.Secundario"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Aplicar"
                    android:textColor="@color/cl_texto_princ"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnResetFilters"
                    style="@style/FinarchButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Reiniciar"
                    android:textColor="@color/cl_texto_princ"
                    app:backgroundTint="@color/cl_principalSc"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/rowSummary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintTop_toBottomOf="@id/cardFilters"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvResultsCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mostrando 0 movimientos"
            android:textColor="@color/cl_text_ter"
            android:textSize="13sp"
            android:fontFamily="@font/inter_regular" />

        <TextView
            android:id="@+id/tvResultsTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total: $0.00"
            android:textColor="@color/cl_texto_princ"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_regular" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMovements"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rowSummary"
        app:layout_constraintVertical_bias="0.0"
        tools:listitem="@layout/item_movement" />


</androidx.constraintlayout.widget.ConstraintLayout>
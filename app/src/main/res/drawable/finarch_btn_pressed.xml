<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Al presionar: sin sombra + desplazado -->
    <item android:left="4dp" android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="?attr/finarchBtnFacePressedColor"/>
            <stroke
                android:width="2dp"
                android:color="?attr/finarchBtnStrokeColor"/>
            <corners android:radius="?attr/finarchBtnRadius"/>
        </shape>
    </item>

</layer-list>
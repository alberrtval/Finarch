<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Fondo base con gradiente -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="600"
                android:centerX="0.2"
                android:centerY="0.3"
                android:startColor="#6C63FF"
                android:centerColor="#3B1FA3"
                android:endColor="#0D0D2B" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- Overlay semitransparente para dar profundidad -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="45"
                android:startColor="#33FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
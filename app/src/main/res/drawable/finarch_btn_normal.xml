<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Sombra -->
    <item android:left="4dp" android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="?attr/finarchBtnShadowColor"/>
            <corners android:radius="?attr/finarchBtnRadius"/>
        </shape>
    </item>

    <!-- Cara del botón -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="?attr/finarchBtnFaceColor"/>
            <stroke
                android:width="2dp"
                android:color="?attr/finarchBtnStrokeColor"/>
            <corners android:radius="?attr/finarchBtnRadius"/>
        </shape>
    </item>

</layer-list>
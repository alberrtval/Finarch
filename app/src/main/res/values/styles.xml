<resources>

    <style name="FinarchButton.Base" parent="Widget.Material3.Button">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">18sp</item>
        <item name="android:letterSpacing">0.08</item>

        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>

        <item name="cornerRadius">8dp</item>

        <!-- Quita insets raros de MaterialButton -->
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- Botón sin efecto 3D -->
    <style name="FinarchButton" parent="FinarchButton.Base">
        <item name="android:elevation">2dp</item>
    </style>

    <!-- Botón con efecto 3D -->
    <style name="FinarchButton3D" parent="FinarchButton.Base">
        <item name="android:background">@drawable/finarch_btn_selector</item>
        <item name="backgroundTint">@null</item>
        <item name="android:elevation">0dp</item>
    </style>

</resources>
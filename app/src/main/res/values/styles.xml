<resources>

    <!-- =========================
         BASE
         ========================= -->
    <style name="FinarchButton.Base" parent="Widget.Material3.Button">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">18sp</item>
        <item name="android:letterSpacing">0.08</item>

        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>

        <item name="cornerRadius">8dp</item>

        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="FinarchButton" parent="FinarchButton.Base">
        <item name="android:elevation">2dp</item>
    </style>

    <style name="ThemeOverlay" />

    <style name="ThemeOverlay.FinarchButton" parent="ThemeOverlay">
        <item name="finarchBtnFaceColor">@color/cl_secundario</item>
        <item name="finarchBtnFacePressedColor">@color/cl_secundarioSc</item>
        <item name="finarchBtnShadowColor">@color/black</item>
        <item name="finarchBtnStrokeColor">@color/black</item>
        <item name="finarchBtnRadius">8dp</item>
    </style>

    <style name="ThemeOverlay.FinarchButton.Secondary" parent="ThemeOverlay.FinarchButton">
        <item name="finarchBtnFaceColor">@color/cl_principal</item>
        <item name="finarchBtnFacePressedColor">@color/cl_principalSc</item>
    </style>

    <!-- =========================
         BOTÓN 3D
         ========================= -->
    <style name="FinarchButton3D" parent="FinarchButton.Base">
        <item name="android:background">@drawable/finarch_btn_selector</item>
        <item name="backgroundTint">@null</item>
        <item name="android:elevation">0dp</item>
        <item name="materialThemeOverlay">@style/ThemeOverlay.FinarchButton</item>
    </style>

    <style name="FinarchButton3D.Secundario" parent="FinarchButton3D">
        <item name="materialThemeOverlay">@style/ThemeOverlay.FinarchButton.Secondary</item>
    </style>

</resources>
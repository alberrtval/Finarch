#############################################
# FIREBASE 🔥 — CRÍTICO PARA TI
#############################################

# Archivo de configuración de Firebase (contiene API keys y project ID)
google-services.json

# Credenciales de Admin SDK (si las usas en scripts o backend)
*-firebase-adminsdk-*.json
firebase-adminsdk*.json
serviceAccountKey.json
service-account*.json
service_account*.json

# Firebase local emulator data
.firebase/
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
database-debug.log
pubsub-debug.log
ui-debug.log
.firebaserc

#############################################
# KEYSTORE Y FIRMA — CRÍTICO
#############################################
*.jks
*.keystore
*.p12
*.pfx
keystore.properties
signing.properties
release-keystore.*
upload-keystore.*
key.properties

#############################################
# VARIABLES DE ENTORNO Y SECRETOS
#############################################
*.env
.env
.env.*
.env.local
.env.production
secrets.properties
secrets.xml
apikeys.properties
api_keys.properties
config.properties
credentials.properties
private.properties

# Nunca subas archivos con tokens o passwords hardcodeados
*secret*
*password*
*credential*
*token*
# Excepciones (archivos de ejemplo que SÍ deben subirse)
!*secret*.example
!*secret*.template
!*credential*.example

#############################################
# BASE DE DATOS — PENSANDO EN TU POSTGRESQL
#############################################
*.sqlite
*.sqlite3
*.db
database.properties
db.properties
db_config.properties
# Credenciales de conexión a Postgres u otra BD relacional
database_url.properties
connection_string.properties
jdbc.properties

